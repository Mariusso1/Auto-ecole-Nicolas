---
// src/components/GoogleReviews.astro

// Placeholder reviews data - to be replaced with actual Google API data
const reviews = [
  {
    id: 1,
    author: "Marie D.",
    rating: 5,
    text: "Excellent moniteur, très patient et professionnel. J'ai réussi mon permis du premier coup ! Je recommande fortement.",
    date: "2024-12-15"
  },
  {
    id: 2,
    author: "Pierre L.",
    rating: 5,
    text: "Très bonne auto-école. Les horaires sont flexibles et les cours de code sont très bien expliqués.",
    date: "2024-11-28"
  },
  {
    id: 3,
    author: "Sophie M.",
    rating: 5,
    text: "Un grand merci à toute l'équipe ! Super accompagnement pendant toute la durée de ma formation.",
    date: "2024-10-10"
  }
];

const getStars = (rating: number) => {
  return Array(5).fill(0).map((_, i) => i < rating);
};

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
};
---

<section class="reviews" id="avis">
  <div class="container">
    <h2 class="reviews__title">Avis de nos élèves</h2>
    <p class="reviews__subtitle">Découvrez les témoignages de nos élèves satisfaits</p>
    
    <div class="reviews__grid">
      {reviews.map((review) => (
        <article class="review-card">
          <div class="review-card__header">
            <div class="review-card__stars" aria-label={`${review.rating} sur 5 étoiles`}>
              {getStars(review.rating).map((filled) => (
                <span class:list={['review-card__star', { 'review-card__star--filled': filled }]}>
                  ★
                </span>
              ))}
            </div>
            <time class="review-card__date" datetime={review.date}>
              {formatDate(review.date)}
            </time>
          </div>
          
          <blockquote class="review-card__text">
            "{review.text}"
          </blockquote>
          
          <footer class="review-card__author">
            <span class="review-card__author-name">{review.author}</span>
          </footer>
        </article>
      ))}
    </div>

    <div class="reviews__cta">
      <a 
        href="https://www.google.com/search?q=auto+%C3%A9cole+castres+nicolas" 
        target="_blank" 
        rel="noopener noreferrer"
        class="btn btn--outline"
      >
        Voir tous les avis sur Google
      </a>
    </div>
  </div>
</section>

<style>
  .reviews {
    background-color: var(--color-light-gray);
    padding: var(--spacing-xl) 0;
  }

  .reviews__title {
    text-align: center;
    margin-bottom: var(--spacing-xs);
  }

  .reviews__subtitle {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-lg);
  }

  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .review-card {
    background-color: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease;
  }

  .review-card:hover {
    box-shadow: var(--shadow-md);
  }

  .review-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
  }

  .review-card__stars {
    display: flex;
    gap: 2px;
  }

  .review-card__star {
    font-size: 1.25rem;
    color: var(--color-border);
  }

  .review-card__star--filled {
    color: var(--color-accent);
  }

  .review-card__date {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .review-card__text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-dark);
    margin-bottom: var(--spacing-sm);
    font-style: italic;
  }

  .review-card__author {
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-sm);
  }

  .review-card__author-name {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-navy);
  }

  .reviews__cta {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .reviews__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
