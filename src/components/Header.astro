---
// src/components/Header.astro
const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/horaires', label: 'Horaires' },
  { href: '/code', label: 'Cours de code' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header__container">
    <a href="/" class="header__logo" aria-label="Auto-École Nicolas - Accueil">
      <span class="header__logo-text">Auto-École Nicolas</span>
    </a>

    <nav class="header__nav" aria-label="Navigation principale">
      <ul class="header__nav-list">
        {navLinks.map((link) => (
          <li class="header__nav-item">
            <a 
              href={link.href} 
              class:list={['header__nav-link', { 'header__nav-link--active': currentPath === link.href }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="header__menu-btn" aria-label="Menu mobile" aria-expanded="false" id="menu-toggle">
      <span class="header__menu-bar"></span>
      <span class="header__menu-bar"></span>
      <span class="header__menu-bar"></span>
    </button>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-toggle');
  const nav = document.querySelector('.header__nav');

  menuBtn?.addEventListener('click', () => {
    const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', String(!isExpanded));
    nav?.classList.toggle('header__nav--open');
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background-color: var(--color-white);
    box-shadow: var(--shadow-sm);
    z-index: 1000;
  }

  .header__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .header__logo-text {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .header__nav-list {
    display: flex;
    gap: var(--spacing-lg);
  }

  .header__nav-link {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-dark);
    padding: var(--spacing-xs) 0;
    position: relative;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width 0.2s ease;
  }

  .header__nav-link:hover::after,
  .header__nav-link--active::after {
    width: 100%;
  }

  .header__nav-link--active {
    color: var(--color-primary);
  }

  /* Mobile Menu Button */
  .header__menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header__menu-bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-navy);
    transition: transform 0.2s ease;
  }

  @media (max-width: 768px) {
    .header__menu-btn {
      display: flex;
    }

    .header__nav {
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      background-color: var(--color-white);
      padding: var(--spacing-md);
      box-shadow: var(--shadow-md);
      transform: translateY(-100%);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .header__nav--open {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    .header__nav-list {
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    .header__nav-link {
      display: block;
      padding: var(--spacing-sm);
    }

    .header__nav-link::after {
      display: none;
    }
  }
</style>
