---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/horaires', label: 'Horaires' },
  { href: '/code', label: 'Cours de code' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="footer">
  <div class="container footer__container">
    <div class="footer__section">
      <h3 class="footer__title">Auto-École Nicolas</h3>
      <p class="footer__text">
        Votre partenaire de confiance pour obtenir votre permis de conduire à Castres.
        Des moniteurs expérimentés à votre service.
      </p>
    </div>

    <div class="footer__section">
      <h3 class="footer__title">Navigation</h3>
      <nav aria-label="Navigation pied de page">
        <ul class="footer__nav-list">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="footer__section">
      <h3 class="footer__title">Contact</h3>
      <address class="footer__address">
        <p>
          <a href="tel:+33563000000" class="footer__link">05 63 00 00 00</a>
        </p>
        <p>
          <a href="mailto:contact@autoecolenicolascastres.com" class="footer__link">
            contact@autoecolenicolascastres.com
          </a>
        </p>
        <p>Castres, Tarn (81)</p>
      </address>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p class="footer__copyright">
        &copy; {currentYear} Auto-École Nicolas. Tous droits réservés.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    color: var(--color-white);
    margin-top: auto;
  }

  .footer__container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
    padding: var(--spacing-xl) var(--spacing-md);
  }

  .footer__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-white);
    margin-bottom: var(--spacing-sm);
  }

  .footer__text {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .footer__link {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--color-white);
  }

  .footer__address {
    font-style: normal;
  }

  .footer__address p {
    margin-bottom: var(--spacing-xs);
    color: rgba(255, 255, 255, 0.8);
  }

  .footer__bottom {
    background-color: rgba(0, 0, 0, 0.2);
    padding: var(--spacing-sm) 0;
  }

  .footer__copyright {
    text-align: center;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer__container {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
      text-align: center;
    }

    .footer__nav-list {
      align-items: center;
    }
  }
</style>
