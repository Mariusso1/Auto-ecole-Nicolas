---
// src/pages/code.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cours de code" description="Cours de code de la route à l'Auto-École Nicolas à Castres">
  <section class="page-header">
    <div class="container">
      <h1>Cours de code</h1>
      <p>Préparez-vous efficacement à l'examen du code de la route</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="code-intro">
        <h2>Formation théorique au code de la route</h2>
        <p>
          L'examen du code de la route est une étape obligatoire pour obtenir votre permis de conduire. 
          Chez Auto-École Nicolas, nous vous proposons une préparation complète et rigoureuse 
          pour mettre toutes les chances de votre côté.
        </p>
      </div>

      <div class="code-features">
        <div class="feature-card">
          <div class="feature-card__icon">📚</div>
          <h3>Supports pédagogiques variés</h3>
          <p>
            Accédez à des supports de cours complets : fiches de révision, vidéos explicatives, 
            et quiz interactifs pour progresser à votre rythme.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">💻</div>
          <h3>Tests en conditions réelles</h3>
          <p>
            Entraînez-vous avec des examens blancs identiques à ceux de l'examen officiel. 
            Évaluez votre niveau et identifiez vos points à améliorer.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">👨‍🏫</div>
          <h3>Encadrement personnalisé</h3>
          <p>
            Nos moniteurs vous accompagnent et répondent à vos questions lors de séances 
            de code collectives ou individuelles.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">⏰</div>
          <h3>Horaires flexibles</h3>
          <p>
            Venez aux cours de code selon vos disponibilités. Nous proposons des créneaux 
            adaptés à tous les emploi du temps.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <h2>Comment se passe la formation ?</h2>
      <div class="steps">
        <div class="step">
          <div class="step__number">1</div>
          <div class="step__content">
            <h3>Inscription</h3>
            <p>Venez nous rencontrer pour vous inscrire et récupérer vos identifiants.</p>
          </div>
        </div>

        <div class="step">
          <div class="step__number">2</div>
          <div class="step__content">
            <h3>Apprentissage</h3>
            <p>Suivez les cours et travaillez vos cours avec nos supports pédagogiques.</p>
          </div>
        </div>

        <div class="step">
          <div class="step__number">3</div>
          <div class="step__content">
            <h3>Entraînement</h3>
            <p>Faites régulièrement des tests pour valider vos connaissances.</p>
          </div>
        </div>

        <div class="step">
          <div class="step__number">4</div>
          <div class="step__content">
            <h3>Examen</h3>
            <p>Présentez l'examen du code de la route en confiance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Informations importantes</h2>
      <div class="info-grid">
        <div class="info-card">
          <h3>Tarif</h3>
          <p>Contactez-nous pour connaître nos tarifs de formation au code.</p>
        </div>

        <div class="info-card">
          <h3>Durée</h3>
          <p>La formation varie selon votre rythme d'apprentissage. En moyenne, comptez 1 à 2 mois.</p>
        </div>

        <div class="info-card">
          <h3>Prérequis</h3>
          <p>Aucun prérequis minimum. Accessible dès 15 ans pour la conduite accompagnée.</p>
        </div>
      </div>

      <div class="code-cta">
        <h3>Vous avez des questions ?</h3>
        <p>N'hésitez pas à nous contacter pour plus d'informations</p>
        <a href="/contact" class="btn btn--primary">Contactez-nous</a>
      </div>
    </div>
  </section>

  <!-- Placeholder for user content -->
  <section class="section section--light">
    <div class="container">
      <div class="coming-soon">
        <h2>Informations complémentaires à venir</h2>
        <p>Des informations supplémentaires sur les cours de code seront ajoutées ultérieurement.</p>
        <p>Revenez bientôt ou contactez-nous directement pour plus de détails.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-navy) 100%);
    padding: var(--spacing-xl) 0;
    text-align: center;
    color: var(--color-white);
  }

  .page-header h1 {
    color: var(--color-white);
    margin-bottom: var(--spacing-xs);
  }

  .page-header p {
    opacity: 0.9;
    margin: 0;
  }

  .code-intro {
    max-width: 800px;
    margin: 0 auto var(--spacing-xl);
    text-align: center;
  }

  .code-intro h2 {
    margin-bottom: var(--spacing-md);
  }

  .code-intro p {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .code-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  .feature-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    transition: box-shadow 0.2s ease;
  }

  .feature-card:hover {
    box-shadow: var(--shadow-md);
  }

  .feature-card__icon {
    font-size: 2rem;
    margin-bottom: var(--spacing-sm);
  }

  .feature-card h3 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xs);
  }

  .feature-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    margin: 0;
  }

  /* Steps */
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .step {
    text-align: center;
    position: relative;
  }

  .step__number {
    width: 50px;
    height: 50px;
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto var(--spacing-sm);
  }

  .step h3 {
    font-size: 1rem;
    margin-bottom: var(--spacing-xs);
  }

  .step p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin: 0;
  }

  /* Info Grid */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .info-card {
    background-color: var(--color-light-gray);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .info-card h3 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xs);
  }

  .info-card p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin: 0;
  }

  .code-cta {
    text-align: center;
    padding: var(--spacing-lg);
    background-color: var(--color-navy);
    border-radius: var(--radius-md);
    color: var(--color-white);
  }

  .code-cta h3 {
    color: var(--color-white);
    margin-bottom: var(--spacing-xs);
  }

  .code-cta p {
    opacity: 0.9;
    margin-bottom: var(--spacing-md);
  }

  .coming-soon {
    text-align: center;
    padding: var(--spacing-lg);
  }

  .coming-soon h2 {
    margin-bottom: var(--spacing-sm);
  }

  .coming-soon p {
    color: var(--color-text-light);
  }

  @media (max-width: 1024px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .code-features {
      grid-template-columns: 1fr;
    }

    .steps,
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
